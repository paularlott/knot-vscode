{
  "name": "knot",
  "displayName": "Knot",
  "description": "Manage Knot cloud development environments from VS Code: list, create, start/stop/restart, web terminal, and run commands in spaces.",
  "version": "0.1.3",
  "publisher": "paularlott",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/paularlott/knot-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "knot",
    "cde",
    "remote",
    "devcontainer",
    "cloud-development"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:knot.spaces",
    "onCommand:knot.login"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "knot",
          "title": "Knot",
          "icon": "media/activitybar.png"
        }
      ]
    },
    "views": {
      "knot": [
        {
          "id": "knot.spaces",
          "name": "Spaces"
        }
      ]
    },
    "commands": [
      {
        "command": "knot.login",
        "title": "Connect to Server",
        "category": "Knot",
        "icon": "$(sign-in)"
      },
      {
        "command": "knot.logout",
        "title": "Disconnect",
        "category": "Knot",
        "icon": "$(sign-out)"
      },
      {
        "command": "knot.refresh",
        "title": "Refresh Spaces",
        "category": "Knot",
        "icon": "$(refresh)"
      },
      {
        "command": "knot.createSpace",
        "title": "Create Space",
        "category": "Knot",
        "icon": "$(add)"
      },
      {
        "command": "knot.deleteSpace",
        "title": "Delete Space",
        "category": "Knot",
        "icon": "$(trash)"
      },
      {
        "command": "knot.startSpace",
        "title": "Start",
        "category": "Knot",
        "icon": "$(debug-start)"
      },
      {
        "command": "knot.stopSpace",
        "title": "Stop",
        "category": "Knot",
        "icon": "$(debug-stop)"
      },
      {
        "command": "knot.restartSpace",
        "title": "Restart",
        "category": "Knot",
        "icon": "$(debug-restart)"
      },
      {
        "command": "knot.startStack",
        "title": "Start Stack",
        "category": "Knot",
        "icon": "$(debug-start)"
      },
      {
        "command": "knot.stopStack",
        "title": "Stop Stack",
        "category": "Knot",
        "icon": "$(debug-stop)"
      },
      {
        "command": "knot.restartStack",
        "title": "Restart Stack",
        "category": "Knot",
        "icon": "$(debug-restart)"
      },
      {
        "command": "knot.openTerminal",
        "title": "Open Terminal",
        "category": "Knot",
        "icon": "$(terminal)"
      },
      {
        "command": "knot.runCommand",
        "title": "Run Command in Space",
        "category": "Knot",
        "icon": "$(play)"
      },
      {
        "command": "knot.openCodeServer",
        "title": "Open Code-Server",
        "category": "Knot",
        "icon": "$(code)"
      },
      {
        "command": "knot.openInBrowser",
        "title": "Open in Browser",
        "category": "Knot",
        "icon": "$(globe)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "knot.refresh",
          "when": "view == knot.spaces",
          "group": "navigation"
        },
        {
          "command": "knot.createSpace",
          "when": "view == knot.spaces",
          "group": "navigation"
        },
        {
          "command": "knot.login",
          "when": "view == knot.spaces",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "knot.startSpace",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "inline@1"
        },
        {
          "command": "knot.stopSpace",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "inline@2"
        },
        {
          "command": "knot.restartSpace",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "inline@3"
        },
        {
          "command": "knot.openTerminal",
          "when": "view == knot.spaces && viewItem =~ /terminal/",
          "group": "inline@4"
        },
        {
          "command": "knot.openTerminal",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "1_actions@1"
        },
        {
          "command": "knot.runCommand",
          "when": "view == knot.spaces && viewItem =~ /terminal/",
          "group": "1_actions@2"
        },
        {
          "command": "knot.openCodeServer",
          "when": "view == knot.spaces && viewItem =~ /code-server/",
          "group": "1_actions@3"
        },
        {
          "command": "knot.openInBrowser",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "1_actions@4"
        },
        {
          "command": "knot.startSpace",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "2_lifecycle@1"
        },
        {
          "command": "knot.stopSpace",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "2_lifecycle@2"
        },
        {
          "command": "knot.restartSpace",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "2_lifecycle@3"
        },
        {
          "command": "knot.deleteSpace",
          "when": "view == knot.spaces && viewItem =~ /^knot-space/",
          "group": "3_delete@1"
        },
        {
          "command": "knot.startStack",
          "when": "view == knot.spaces && viewItem == knot-stack",
          "group": "inline@1"
        },
        {
          "command": "knot.stopStack",
          "when": "view == knot.spaces && viewItem == knot-stack",
          "group": "inline@2"
        },
        {
          "command": "knot.restartStack",
          "when": "view == knot.spaces && viewItem == knot-stack",
          "group": "inline@3"
        },
        {
          "command": "knot.startStack",
          "when": "view == knot.spaces && viewItem == knot-stack",
          "group": "1_lifecycle@1"
        },
        {
          "command": "knot.stopStack",
          "when": "view == knot.spaces && viewItem == knot-stack",
          "group": "1_lifecycle@2"
        },
        {
          "command": "knot.restartStack",
          "when": "view == knot.spaces && viewItem == knot-stack",
          "group": "1_lifecycle@3"
        }
      ]
    },
    "configuration": {
      "title": "Knot",
      "properties": {
        "knot.serverUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the Knot server, e.g. https://knot.example.com"
        },
        "knot.insecureSkipVerify": {
          "type": "boolean",
          "default": false,
          "description": "Skip TLS certificate verification (for self-signed certs in local dev)."
        },
        "knot.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically poll for space status changes."
        },
        "knot.refreshInterval": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "description": "Auto-refresh interval in seconds."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "ws": "^8.18.0"
  }
}
